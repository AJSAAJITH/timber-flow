generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ==========================================
// 1. ENUMS (System Constants)
// ==========================================

enum Role {
  SUPER_ADMIN
  ADMIN
  CASHIER
}

enum PaymentMethod {
  CASH
  CREDIT
  BANK_TRANSFER
}

enum PaymentStatus {
  PAID
  PENDING
  PARTIALLY_PAID
}

enum InventoryLogType {
  STOCK_IN // අලුතෙන් තොග ඇතුලත් කිරීම්
  SALE // විකිණීම නිසා අඩුවීම්
  STOCK_TRANSFER // ශාඛා අතර තොග හුවමාරු
  ADJUSTMENT // හානිවීම් හෝ වෙනත් සංශෝධන
}

// ==========================================
// 2. CORE MODELS
// ==========================================

model Branch {
  id       String  @id @default(cuid())
  name     String
  location String?

  users         User[]
  inventory     BranchInventory[]
  sales         Sale[]
  expenses      Expense[]
  inventoryLogs InventoryLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model User {
  id      String @id @default(cuid())
  clerkId String @unique
  name    String
  email   String @unique
  role    Role   @default(CASHIER)

  branchId String?
  branch   Branch? @relation(fields: [branchId], references: [id])

  sales          Sale[]
  expenses       Expense[]
  inventoryLogs  InventoryLog[]
  creditPayments CreditPaymentLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ==========================================
// 3. PRODUCT & INVENTORY MODELS
// ==========================================

model Category {
  id       String    @id @default(cuid())
  name     String // e.g., "Teak Logs", "Mahogany Planks", "Plywood Boards"
  products Product[]
}

model Product {
  id   String  @id @default(cuid())
  name String // e.g., "Teak Plank 2x4x10", "Plywood 3x3"
  sku  String? @unique

  categoryId String
  category   Category @relation(fields: [categoryId], references: [id])

  unitPrice Float

  inventory     BranchInventory[]
  saleItems     SaleItem[]
  inventoryLogs InventoryLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model BranchInventory {
  id       String @id @default(cuid())
  branchId String
  branch   Branch @relation(fields: [branchId], references: [id])

  productId String
  product   Product @relation(fields: [productId], references: [id])

  stockLevel Int @default(0)
  minStock   Int @default(10)

  @@unique([branchId, productId])
}

// 💡 අලුත්: තොග වෙනස්වීම් හරියටම ට්‍රැක් කිරීමට
model InventoryLog {
  id       String           @id @default(cuid())
  type     InventoryLogType
  quantity Int // වෙනස් වූ ප්‍රමාණය (+ හෝ -)
  note     String? // e.g., "Bulk purchase incoming"

  branchId String
  branch   Branch @relation(fields: [branchId], references: [id])

  productId String
  product   Product @relation(fields: [productId], references: [id])

  userId String
  user   User   @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
}

// ==========================================
// 4. CUSTOMER & CREDIT MODELS
// ==========================================

model Customer {
  id       String  @id @default(cuid())
  name     String
  phone    String?
  totalDue Float   @default(0)

  sales          Sale[]
  creditPayments CreditPaymentLog[] // 💡 කස්ටමර් ණය පියවපු හිස්ට්‍රි එක

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// 💡 අලුත්: ණය පියවීම් ට්‍රැක් කරන ටේබල් එක
model CreditPaymentLog {
  id         String  @id @default(cuid())
  amountPaid Float
  note       String? // e.g., "Paid via bank transfer"

  customerId String
  customer   Customer @relation(fields: [customerId], references: [id])

  userId String // සල්ලි බාරගත්ත Cashier
  user   User   @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
}

// ==========================================
// 5. SALES & FINANCE MODELS
// ==========================================

model Sale {
  id            String  @id @default(cuid())
  invoiceNumber String? @unique // e.g., INV-2026-0001
  totalAmount   Float
  paidAmount    Float   @default(0)
  dueAmount     Float   @default(0)

  paymentMethod PaymentMethod @default(CASH)
  paymentStatus PaymentStatus @default(PAID)

  branchId String
  branch   Branch @relation(fields: [branchId], references: [id])

  userId String
  user   User   @relation(fields: [userId], references: [id])

  customerId String?
  customer   Customer? @relation(fields: [customerId], references: [id])

  items     SaleItem[]
  createdAt DateTime   @default(now())
}

model SaleItem {
  id     String @id @default(cuid())
  saleId String
  sale   Sale   @relation(fields: [saleId], references: [id])

  productId String
  product   Product @relation(fields: [productId], references: [id])

  quantity    Int
  priceAtSale Float
}

model Expense {
  id          String @id @default(cuid())
  amount      Float
  description String
  type        String @default("GENERAL") // "GENERAL", "PROFIT_WITHDRAWAL", "SALARY"

  branchId String
  branch   Branch @relation(fields: [branchId], references: [id])

  userId String
  user   User   @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
}
