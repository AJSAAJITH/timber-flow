generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ==========================================
// 1. ENUMS (System Constants)
// ==========================================

enum Role {
  SUPER_ADMIN
  ADMIN
  CASHIER
}

enum PaymentMethod {
  CASH
  CREDIT
  BANK_TRANSFER
}

enum PaymentStatus {
  PAID
  PENDING
  PARTIALLY_PAID
}

enum InventoryLogType {
  STOCK_IN
  STOCK_OUT
  ADJUSTMENT
  DAMAGE
  RETURN
}

// 💡 වියදම් වර්ග වර්ගීකරණය කිරීමට Enum එකක් එකතු කලා
enum ExpenseType {
  GENERAL
  PROFIT_WITHDRAWAL // 👈 කවුන්ටරයෙන් මුදල් ලබා ගැනීම් (Owner/Admin cashout)
  SALARY
  PETTY_CASH // එදිනෙදා සුළු වියදම් (කෑම, ප්‍රවාහන, ආදී)
  BILL_PAYMENT // ලයිට් බිල්, වතුර බිල්, කුලී
}

// ==========================================
// 2. CORE MODELS
// ==========================================

model Branch {
  id        String  @id @default(cuid())
  name      String
  location  String?
  isBlocked Boolean @default(false)

  users          User[]
  inventory      BranchInventory[]
  sales          Sale[]
  expenses       Expense[]
  inventoryLogs  InventoryLog[]
  creditPayments CreditPaymentLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model User {
  id        String  @id @default(cuid())
  clerkId   String  @unique
  name      String
  email     String  @unique
  role      Role    @default(CASHIER)
  isBlocked Boolean @default(false)

  branchId String?
  branch   Branch? @relation(fields: [branchId], references: [id])

  sales          Sale[]
  expenses       Expense[]
  inventoryLogs  InventoryLog[]
  creditPayments CreditPaymentLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ==========================================
// 3. PRODUCT & INVENTORY MODELS
// ==========================================

model Category {
  id       String    @id @default(cuid())
  name     String
  products Product[]
}

model Product {
  id   String  @id @default(cuid())
  name String
  sku  String? @unique

  categoryId String
  category   Category @relation(fields: [categoryId], references: [id])

  unitPrice Decimal @db.Decimal(10, 2)

  inventory     BranchInventory[]
  saleItems     SaleItem[]
  inventoryLogs InventoryLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model BranchInventory {
  id       String @id @default(cuid())
  branchId String
  branch   Branch @relation(fields: [branchId], references: [id])

  productId String
  product   Product @relation(fields: [productId], references: [id])

  stockLevel Int @default(0)
  minStock   Int @default(10)

  @@unique([branchId, productId])
}

model InventoryLog {
  id       String           @id @default(cuid())
  type     InventoryLogType
  quantity Int
  note     String?

  branchId String
  branch   Branch @relation(fields: [branchId], references: [id])

  productId String
  product   Product @relation(fields: [productId], references: [id])

  userId String
  user   User   @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
}

// ==========================================
// 4. CUSTOMER & CREDIT MODELS
// ==========================================

model Customer {
  id       String  @id @default(cuid())
  name     String
  phone    String?
  nic      String? @unique
  address  String?
  totalDue Decimal @default(0) @db.Decimal(10, 2)

  sales          Sale[]
  creditPayments CreditPaymentLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CreditPaymentLog {
  id         String  @id @default(cuid())
  amountPaid Decimal @db.Decimal(10, 2)
  note       String?

  customerId String
  customer   Customer @relation(fields: [customerId], references: [id])

  branchId String
  branch   Branch @relation(fields: [branchId], references: [id])

  userId String
  user   User   @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
}

// ==========================================
// 5. SALES & FINANCE MODELS
// ==========================================

model Sale {
  id            String  @id @default(cuid())
  invoiceNumber String? @unique
  totalAmount   Decimal @db.Decimal(10, 2)
  paidAmount    Decimal @default(0) @db.Decimal(10, 2)
  dueAmount     Decimal @default(0) @db.Decimal(10, 2)

  paymentMethod PaymentMethod @default(CASH)
  paymentStatus PaymentStatus @default(PAID)

  branchId String
  branch   Branch @relation(fields: [branchId], references: [id])

  userId String
  user   User   @relation(fields: [userId], references: [id])

  customerId String?
  customer   Customer? @relation(fields: [customerId], references: [id])

  items     SaleItem[]
  createdAt DateTime   @default(now())
}

model SaleItem {
  id            String  @id @default(cuid())
  saleId        String
  sale          Sale    @relation(fields: [saleId], references: [id])
  productId     String
  product       Product @relation(fields: [productId], references: [id])
  quantity      Int
  originalPrice Decimal @db.Decimal(10, 2)
  priceAtSale   Decimal @db.Decimal(10, 2)
}

model Expense {
  id          String      @id @default(cuid())
  amount      Decimal     @db.Decimal(10, 2)
  description String // 👈 සල්ලි ගත්තේ ඇයි කියන හේතුව (Reason)
  type        ExpenseType @default(GENERAL) // 👈 String වෙනුවට Enum එක දැම්මා

  branchId String
  branch   Branch @relation(fields: [branchId], references: [id])

  userId String // 👈 සල්ලි Checkout කරපු / වියදම් කරපු Admin
  user   User   @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
}
